class Solution {
    public int divide(int dividend, int divisor) {
         int count = 0;
         int sign = 1;

         if(dividend < 0 && divisor > 0 || dividend > 0 && divisor < 0){
            sign = -1;
        }

        dividend = Math.abs(dividend);
        divisor = Math.abs(divisor);

        while(dividend >= divisor){
            dividend = dividend - divisor;
            count++;
        }

        return sign * count;
    }
}
